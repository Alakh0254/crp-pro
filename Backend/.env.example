# Backend environment configuration — COPY this file to .env and fill in values.
# .env is git-ignored (it holds your local/dev settings); THIS example is
# committed to document the keys and must NEVER contain a real secret.

# Which environment this process runs as. "dev" is forgiving about a missing
# SECRET_KEY (it falls back to an insecure key and warns); any other value
# (e.g. "staging" / "prod") makes the app refuse to start without one.
APP_ENV=dev

# Secret used to sign JWTs. In dev you may leave this blank. For any non-dev
# environment set a long random value, e.g. generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# How long an access token stays valid, in minutes. Optional (defaults to 60).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLAlchemy database URL. Optional (defaults to the local SQLite file).
DATABASE_URL=sqlite:///./app.db
# For PostgreSQL (synchronous psycopg2 driver), point at your Postgres instead:
#   DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/crp

# Comma-separated browser origins allowed to call this API (CORS).
# Optional (defaults to the Vite dev server). Example for two origins:
#   CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# Frontend environment configuration — COPY this file to .env and adjust if needed.
# Vite only exposes variables prefixed with VITE_ to the app, and inlines them at
# build time. .env is git-ignored; this committed example must hold NO secrets —
# anything here is shipped to the browser and is fully public.

# Base URL of the FastAPI backend. Optional — api.ts defaults to this same value
# when unset, so you only need it to point the frontend at a different backend.
VITE_API_URL=http://localhost:8000
